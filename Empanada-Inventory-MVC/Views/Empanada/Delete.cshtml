@model ProyectoEmpanadas.Models.Empanada

<h1>Eliminar Empanada</h1>
<h3>øEst·s seguro de que quieres eliminar esta empanada?</h3>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Sabor</dt>
        <dd class="col-sm-10">@Model.Sabor</dd>

        <dt class="col-sm-2">Precio</dt>
        <dd class="col-sm-10">@Model.Precio.ToString("C")</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Eliminar Definitivamente</button> |
        <a asp-action="Index">Cancelar y volver</a>
    </form>
</div>