@model IEnumerable<EmpanadaInventory.Models.Empanada>

    @{
    ViewData["Title"] = "Inventario de Empanadas";
    }

    <style>
        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', sans-serif;
        }

        .page-header {
            background: linear-gradient(135deg, #c0392b, #e74c3c);
            color: white;
            padding: 30px 40px;
            border-radius: 12px;
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 15px rgba(192, 57, 43, 0.3);
        }

            .page-header h2 {
                margin: 0;
                font-size: 1.8rem;
                font-weight: 700;
                letter-spacing: 0.5px;
            }

            .page-header p {
                margin: 4px 0 0;
                opacity: 0.85;
                font-size: 0.95rem;
            }

        .btn-nueva {
            background-color: white;
            color: #c0392b;
            border: none;
            padding: 10px 22px;
            border-radius: 8px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
            white-space: nowrap;
        }

            .btn-nueva:hover {
                background-color: #fdecea;
                color: #a93226;
            }

        .card-tabla {
            background: white;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            overflow: hidden;
        }

        .table {
            margin: 0;
        }

            .table thead {
                background-color: #2c3e50;
                color: white;
            }

                .table thead th {
                    padding: 14px 20px;
                    font-weight: 600;
                    font-size: 0.85rem;
                    text-transform: uppercase;
                    letter-spacing: 0.5px;
                    border: none;
                }

            .table tbody tr {
                border-bottom: 1px solid #f0f0f0;
                transition: background 0.15s;
            }

                .table tbody tr:hover {
                    background-color: #fef9f9;
                }

            .table tbody td {
                padding: 14px 20px;
                vertical-align: middle;
                color: #333;
            }

        .sabor-badge {
            font-weight: 600;
            color: #2c3e50;
        }

        .precio {
            font-weight: 700;
            color: #27ae60;
            font-size: 1rem;
        }

        .stock-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-weight: 600;
            font-size: 0.85rem;
        }

        .stock-ok {
            background-color: #eafaf1;
            color: #1e8449;
        }

        .stock-low {
            background-color: #fef9e7;
            color: #d68910;
        }

        .stock-critical {
            background-color: #fdedec;
            color: #c0392b;
        }

        .btn-editar {
            background-color: #2980b9;
            color: white;
            border: none;
            padding: 6px 14px;
            border-radius: 6px;
            font-size: 0.82rem;
            font-weight: 500;
            text-decoration: none;
            margin-right: 6px;
            transition: background 0.2s;
        }

            .btn-editar:hover {
                background-color: #1f618d;
                color: white;
            }

        .btn-eliminar {
            background-color: #e74c3c;
            color: white;
            border: none;
            padding: 6px 14px;
            border-radius: 6px;
            font-size: 0.82rem;
            font-weight: 500;
            text-decoration: none;
            transition: background 0.2s;
        }

            .btn-eliminar:hover {
                background-color: #a93226;
                color: white;
            }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #aaa;
        }

            .empty-state span {
                font-size: 3rem;
                display: block;
                margin-bottom: 10px;
            }
    </style>

    <div class="container py-4">
        <div class="page-header">
            <div>
                <h2>🫓 Inventario de Empanadas</h2>
                <p>Gestiona tus sabores, precios y existencias</p>
            </div>
            <a asp-action="Create" class="btn-nueva">+ Nueva Empanada</a>
        </div>

        <div class="card-tabla">
            <table class="table">
                <thead>
                    <tr>
                        <th>Sabor</th>
                        <th>Precio</th>
                        <th>Existencia</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4">
                            <div class="empty-state">
                                <span>🫙</span>
                                No hay empanadas registradas aún.
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        string stockClass = item.CantidadInventario >= 10 ? "stock-ok"
                                         : item.CantidadInventario >= 4 ? "stock-low"
                                         : "stock-critical";
                    <tr>
                        <td class="sabor-badge">@item.Sabor</td>
                        <td class="precio">@item.Precio.ToString("C")</td>
                        <td>
                            <span class="stock-badge @stockClass">@item.CantidadInventario uds.</span>
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-editar">✏️ Editar</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-eliminar"
                               onclick="return confirm('¿Seguro que deseas eliminar esta empanada?')">
                                🗑️ Eliminar
                            </a>
                        </td>
                    </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
