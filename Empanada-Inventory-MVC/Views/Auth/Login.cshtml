@model EmpanadaInventory.Models.LoginViewModel
@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Empanada Inventory</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg, #c0392b, #2c3e50);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
        }

        .login-card {
            background: white;
            border-radius: 16px;
            padding: 45px 40px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }

        .login-icon {
            font-size: 3rem;
            text-align: center;
            margin-bottom: 8px;
        }

        .login-title {
            text-align: center;
            font-size: 1.5rem;
            font-weight: 700;
            color: #2c3e50;
            margin-bottom: 4px;
        }

        .login-subtitle {
            text-align: center;
            color: #888;
            font-size: 0.88rem;
            margin-bottom: 28px;
        }

        .form-label {
            font-weight: 600;
            color: #2c3e50;
            font-size: 0.88rem;
        }

        .form-control {
            border-radius: 8px;
            border: 1.5px solid #e0e0e0;
            padding: 10px 14px;
        }

            .form-control:focus {
                border-color: #e74c3c;
                box-shadow: 0 0 0 3px rgba(231,76,60,0.1);
            }

        .btn-login {
            background: linear-gradient(135deg, #c0392b, #e74c3c);
            color: white;
            border: none;
            width: 100%;
            padding: 12px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 1rem;
            margin-top: 8px;
            transition: opacity 0.2s;
        }

            .btn-login:hover {
                opacity: 0.88;
                color: white;
            }

            .btn-login:disabled {
                opacity: 0.45;
                cursor: not-allowed;
            }

        .error-box {
            background-color: #fdedec;
            border-left: 4px solid #e74c3c;
            border-radius: 8px;
            padding: 10px 14px;
            color: #922b21;
            font-size: 0.88rem;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-icon">🫓</div>
        <div class="login-title">Empanada Inventory</div>
        <div class="login-subtitle">Ingresa tus credenciales para continuar</div>

        @if (ViewBag.Error != null)
        {
        <div class="error-box" id="error-msg">⚠️ @ViewBag.Error</div>
        }

        <form asp-action="Login" asp-controller="Auth" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">Usuario</label>
                <input asp-for="Usuario" id="usuario" class="form-control"
                       placeholder="Ej: admin" autocomplete="off"
                       oninput="verificarCampos()" />
                <span asp-validation-for="Usuario" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Contraseña</label>
                <input asp-for="Password" id="password" class="form-control"
                       placeholder="••••••••"
                       oninput="verificarCampos()" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <button type="submit" id="btnEntrar" class="btn-login" disabled>Entrar</button>
        </form>

        <script>
            function verificarCampos() {
                const usuario = document.getElementById('usuario').value.trim();
                const password = document.getElementById('password').value.trim();
                document.getElementById('btnEntrar').disabled = !(usuario && password);
            }
        </script>
    </div>
</body>
</html>